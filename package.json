{
  "name": "@zap-proto/wasm",
  "version": "1.0.1",
  "description": "ZAP Protocol WebAssembly bindings for browser and Node.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zap-proto/wasm.git"
  },
  "homepage": "https://github.com/zap-proto/wasm",
  "keywords": [
    "zap",
    "mcp",
    "webassembly",
    "wasm",
    "browser-extension",
    "rpc",
    "binary-protocol"
  ],
  "files": [
    "pkg/*"
  ],
  "main": "pkg/wasm.js",
  "module": "pkg/wasm.js",
  "types": "pkg/wasm.d.ts",
  "sideEffects": [
    "./pkg/wasm.js"
  ],
  "exports": {
    ".": {
      "import": "./pkg/wasm.js",
      "require": "./pkg/wasm.js",
      "types": "./pkg/wasm.d.ts"
    },
    "./bundler": {
      "import": "./pkg/bundler/wasm.js",
      "types": "./pkg/bundler/wasm.d.ts"
    },
    "./nodejs": {
      "import": "./pkg/nodejs/wasm.js",
      "require": "./pkg/nodejs/wasm.js",
      "types": "./pkg/nodejs/wasm.d.ts"
    }
  },
  "scripts": {
    "build": "make build",
    "build:web": "wasm-pack build --target web --out-dir pkg",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg/bundler",
    "build:nodejs": "wasm-pack build --target nodejs --out-dir pkg/nodejs",
    "build:all": "npm run build:web && npm run build:bundler && npm run build:nodejs",
    "test": "wasm-pack test --headless --firefox",
    "clean": "rm -rf pkg target"
  },
  "devDependencies": {
    "wasm-pack": "^0.15.0"
  }
}
